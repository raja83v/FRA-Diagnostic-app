# FRA Diagnostic App - Root .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Database
*.db
*.sqlite3

# Uploads
uploads/

# Environment
.env
.env.local

# IDE
.vscode/settings.json
.idea/

# OS
Thumbs.db
.DS_Store

# Node
node_modules/
frontend/dist/
frontend/build/

# ML Models (large binary files - regenerate with: python ml/train_and_evaluate.py)
ml/saved_models/*.joblib
ml/saved_models/*.pkl
ml/saved_models/*.pt
ml/saved_models/*.pth
# Keep JSON metadata (feature_names, metrics) - they are small and useful for reference

# Synthetic training data (large, regeneratable)
ml/data_generation/training_data.npz
ml/data_generation/*.npz

# Logs
*.log
